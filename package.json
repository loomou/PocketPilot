{
  "name": "pocketpilot",
  "version": "0.1.0",
  "description": "A self-hosted Windows Agent for controlling local Claude Code sessions from mobile.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=10.14.0 <11"
  },
  "bin": {
    "agent": "./dist/cli.js"
  },
  "files": [
    "dist",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node dist/generate-openapi.js && node scripts/copy-runtime-assets.mjs && pnpm --filter @pocketpilot/local-admin build",
    "build:admin": "pnpm --filter @pocketpilot/local-admin build",
    "dev": "node --watch --experimental-strip-types src/cli.ts start",
    "dev:admin": "pnpm --filter @pocketpilot/local-admin dev",
    "start": "node dist/cli.js start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit && pnpm --filter @pocketpilot/local-admin typecheck",
    "test": "vitest run && pnpm --filter @pocketpilot/local-admin test",
    "test:sdk:live": "node scripts/run-claude-sdk-live-tests.mjs",
    "test:release:windows": "pnpm build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-release-smoke.ps1",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.210",
    "@fastify/static": "8.3.0",
    "@fastify/swagger": "9.8.1",
    "@fastify/swagger-ui": "5.2.6",
    "@fastify/websocket": "11.3.0",
    "better-sqlite3": "12.11.1",
    "commander": "15.0.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "fastify": "5.10.0",
    "fastify-type-provider-zod": "7.0.0",
    "pino": "10.3.1",
    "proper-lockfile": "4.1.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.13.3",
    "@types/proper-lockfile": "4.1.4",
    "drizzle-kit": "0.31.10",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "openapi-types": "12.1.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  }
}
