# Required for Agent startup. Generate a 32-byte unpadded base64url value.
AGENT_MASTER_KEY=

# Set only while running `agent rekey`, then remove it after rotation.
# AGENT_NEW_MASTER_KEY=

# Optional Agent data location. Relative paths resolve from the startup cwd.
# POCKETPILOT_DATA_DIR=D:\PocketPilotData

# Optional loopback-only local administration port (default: 43183).
# POCKETPILOT_LOCAL_ADMIN_PORT=43183
